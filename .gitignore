# ==========================================
# Root Gitignore for AegisAI
# ==========================================

# 1. Environment Variables & Secrets
.env
.env.*
!.env.example
!.env.sample

# 2. Virtual Environments & Dependencies
venv/
.venv/
env/
ENV/
node_modules/
*.egg-info/
.installed.cfg
*.egg

# 3. Cache & Compiled Files
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/
*.log
dist/
build/
.next/
.out/
*.tfstate
*.tfstate.*
.terraform/

# 4. Large Model Weights & Checkpoints (Exceeds GitHub 100MB limit & bloats repo)
*.pth
*.pt
*.pkl
*.joblib
*.h5
*.keras
*.onnx
*.safetensors
*.bin
*.model
models/

# 5. Datasets & Local Storage
data/
blockchain_data/
synthetic_docs/
*.arff
*.parquet
*.db
*.sqlite3
*.sqlite

# 6. Backups & Temp Files
ai-mentor-OLD-BACKUP/
*.tmp
*.bak
*.swp
*~
.DS_Store
*.zip
*.tar.gz

# 7. Personal & Interview Notes
*INTERVIEW_PREP*.md
AEGISAI_INTERVIEW_PREP.md
ml_structure.txt
*_structure.txt


